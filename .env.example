# Copiez en .env.local pour le dev local avec Vercel CLI (vercel dev)
# Sur Vercel : Project → Settings → Environment Variables

ADMIN_PIN=votre-code-secret

# ── Tournois (obligatoire sur Vercel — gratuit) ──────────────────────────────
# 1. Créez un projet sur https://supabase.com (plan Free)
# 2. SQL Editor → exécutez le fichier supabase/schema.sql
# 3. Settings → API → copiez l'URL et la clé service_role (secrète, jamais côté client)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Portraits uniquement (Vercel Blob) ───────────────────────────────────────
# BLOB_READ_WRITE_TOKEN=  → Vercel Storage → Blob
# BLOB_ACCESS=public      → optionnel ; "private" si store privé
# Sur Vercel, BLOB_STORE_ID + OIDC suffisent pour les portraits.

# SHEET_ID=1o9A924ybUdpSoM9AQ6nOeyuft6lytrgXG3pIKFLXvBk
# SHEET_NAME=Feuille 1
